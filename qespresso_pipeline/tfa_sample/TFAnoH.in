  ecutwfc=60,
  ecutrho=480,
  input_dft='pbe',
  occupations='fixed',
  vdw_corr='grimme-d3'
/
&ELECTRONS
  conv_thr=1d-07,
  mixing_beta=0.3,
/
&IONS
  ion_dynamics='bfgs',
/
