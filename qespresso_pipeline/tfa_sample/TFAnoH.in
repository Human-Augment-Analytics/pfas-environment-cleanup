&CONTROL
  calculation='relax',
  outdir='./Outputs',
  prefix='tfanoh_isolated',
  pseudo_dir='./Pseudopotentials',
  verbosity='low',
  tprnfor=.true.,
  tstress=.true.,
  forc_conv_thr=7.7D-4,
  etot_conv_thr=7.3D-7
/
&SYSTEM
